# ==============================================================================
# CyberRiskInsurance Environment Variables Template
# Copy this file to '.env' and fill in the values for deployment or local testing.
# ==============================================================================

# --- Option A: Azure OpenAI Configuration (For Corporate/Deployment Environment) ---
AZURE_OPENAI_API_KEY="your-azure-api-key"
AZURE_OPENAI_ENDPOINT="https://your-resource-name.openai.azure.com/"
AZURE_OPENAI_API_VERSION="2024-02-15-preview"
AZURE_OPENAI_DEPLOYMENT="your-deployment-name"  # e.g., gpt-4o-mini or gpt-4o

# --- Option B: Standard OpenAI Configuration (Alternative Azure/Personal Setup) ---
# OPENAI_API_KEY="your-openai-api-key"
# OPENAI_MODEL="gpt-4o-mini"

# --- Option C: Groq Configuration (For Local/Developer Testing) ---
# GROQ_API_KEY="your-groq-api-key"
# GROQ_MODEL="llama-3.3-70b-versatile"

# --- Search API Configuration (Required for live data scraping) ---
SERPAPI_API_KEY="your-serpapi-api-key"
